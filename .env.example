# Secrets are NOT stored in this repo. They come from Bitwarden Secrets Manager,
# injected at launch via `bws run` (see the `claude-secure` shell function in the README).
#
# This file documents the variables the artifacts expect — copy to `.env` only for
# local/manual testing, never commit a real `.env`.

# --- Bitwarden Secrets Manager bootstrap ---
# Access token for the scoped machine account (read-only on the `claude-code` project).
# In normal use this lives in ~/.config/bws/token (chmod 600), not here.
BWS_ACCESS_TOKEN=

# --- Secrets pulled from Bitwarden (key names must match the BWS secret keys) ---
# TrueNAS API key — consumed by the `truenas` MCP (mcp/truenas/main.py).
TRUENAS_API_KEY=

# --- Non-secret config (safe defaults, override if your host differs) ---
TRUENAS_HOST=http://192.168.7.17
